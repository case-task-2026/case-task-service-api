root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.kt]
indent_size = 2
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL

[*.kts]
indent_size = 2
ij_kotlin_code_style_defaults = KOTLIN_OFFICIAL

[*.yaml]
indent_size = 2